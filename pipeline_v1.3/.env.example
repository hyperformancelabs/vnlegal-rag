# Copy this file to `.env` (same folder or the repo root) and fill in real values.
# `.env` is gitignored so secrets stay local.

# --- Groq LLM (required for verified answers + retrieval rating) ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- Answer / retrieval tunables (optional, defaults shown) ---
ANSWER_TOP_K=3
ANSWER_MIN_RATING=6
ANSWER_CTX_CHAR_LIMIT=1800
MIN_QUERY_WORDS=4
MIN_TOPIC_CONFIDENCE=0.35
MIN_RETRIEVAL_SCORE=0.45
